# ============================================================
# 環境変数テンプレート
# このファイルを `.env.local` にコピーし、実値を埋めて使う:
#   cp .env.local.example .env.local
# .env.local は .gitignore 済（コミットされない）
# ============================================================

# ─── Supabase ───────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API から取得
# https://supabase.com/dashboard/project/<project_id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Publishable key（旧 anon key）。ブラウザ露出 OK
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Service Role Key（Server Actions の admin 操作のみ使用、絶対に NEXT_PUBLIC_ を付けない）
# 例: ユーザー作成 / パスワードリセット / 削除 (RLS バイパス)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# ─── Google OAuth (Calendar 連携専用) ──────────────────────
# Google Cloud Console → 認証情報 → OAuth クライアント ID から取得
# https://console.cloud.google.com/apis/credentials
# 取得手順は docs/SETUP.md 参照
GOOGLE_OAUTH_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# ─── アプリ URL ─────────────────────────────────────────────
# Calendar OAuth のリダイレクト先計算に使用
# ローカル: http://localhost:3000
# 本番:    https://nds-sales-dashboard.vercel.app（または独自ドメイン）
NEXT_PUBLIC_APP_URL=http://localhost:3000
