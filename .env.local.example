# ─── Supabase ───
# Project Settings → API から取得
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...

# Service Role Key（Server Actions の admin 操作のみ使用、ブラウザに絶対露出しない）
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...

# ─── Google OAuth (Calendar 連携専用) ───
# Google Cloud Console → 認証情報 → OAuth クライアント ID から取得
GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxx

# ─── アプリ URL ───
# Calendar OAuth のリダイレクト先計算に使用
# ローカル: http://localhost:3000 / 本番: https://xxx.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
