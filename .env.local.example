# Supabase（フェーズ1 Step 5 以降で使用）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role（Server Actions での admin 操作のみ使用。ブラウザには絶対に露出しないこと）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google OAuth はSupabase Authentication設定で管理
# （Next.js 側には Client ID / Secret を持たせる必要なし）
