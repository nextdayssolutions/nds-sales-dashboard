# ============================================================
# ローカル Supabase（Docker）用 env テンプレート
#
# 使い方（本番用の .env.local には触れない）:
#   1. Docker Desktop を起動
#   2. `npm run db:start` で Supabase 一式を立ち上げ
#   3. `cp .env.docker.local.example .env.docker.local`
#   4. 下記の anon / service_role を `npm run db:status` の出力で置換
#   5. `npm run db:reset` で migrations 適用
#   6. `npm run db:seed:dev` で dev テストユーザー作成
#   7. `npm run dev:local` で http://localhost:3000 （ローカル DB に接続）
#
# 本番 DB を見たい時は `npm run dev`（.env.local が使われる）
# ============================================================

# ─── ローカル Supabase 接続情報 ─────────────────────────────
# CLI のデフォルトポート: API=54321, DB=54322, Studio=54323
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321

# ⚠️ 以下 2 つは `npx supabase status` の出力で必ず置換すること
#    （CLI のバージョンや project_id によって値が変わるため）
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_OUTPUT_OF_supabase_status
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_OUTPUT_OF_supabase_status

# ─── アプリ URL ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Google OAuth（Calendar 連携、ローカルで試したい場合のみ）─
# Google Cloud Console の OAuth 認可済みリダイレクト URI に
# http://localhost:3000/api/calendar/callback を追加しておくこと。
# 不要なら空欄のままで問題ない。
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─── DEV: ロール別クイックログイン ──────────────────────────
# `npm run db:seed:dev` で作成されるテストユーザーに合わせた値。
# ローカルの login 画面下部のショートカットでワンクリックサインイン可能。
NEXT_PUBLIC_DEV_QUICK_LOGIN_ADMIN_EMAIL=dev-admin@nds.test
NEXT_PUBLIC_DEV_QUICK_LOGIN_ADMIN_PASSWORD=devpass1234
NEXT_PUBLIC_DEV_QUICK_LOGIN_MANAGER_EMAIL=dev-manager@nds.test
NEXT_PUBLIC_DEV_QUICK_LOGIN_MANAGER_PASSWORD=devpass1234
NEXT_PUBLIC_DEV_QUICK_LOGIN_MEMBER_EMAIL=dev-member@nds.test
NEXT_PUBLIC_DEV_QUICK_LOGIN_MEMBER_PASSWORD=devpass1234
